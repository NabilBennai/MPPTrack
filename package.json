    "@tailwindcss/cli": "^4.3.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "concurrently": "^9.2.3",
    "nodemon": "^3.1.14",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
