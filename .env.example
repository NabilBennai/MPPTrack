# ============================================================
# API Mon Petit Prono — https://api.mpp.football
# ============================================================

# Refresh token — copier UNE SEULE FOIS depuis DevTools :
# Application → Local Storage → https://mpp.football
# Clé : com.monpetitprono.monpetitpronoapp.secureStorage\refreshToken
# Le serveur rafraîchit l'access token automatiquement ensuite.
# Ne jamais committer la valeur réelle.
MPP_REFRESH_TOKEN=

# Access token direct (optionnel — utilisé en fallback si pas de refresh token)
# DevTools → Network → n'importe quelle requête → header Authorization (sans "Bearer ")
MPP_ACCESS_TOKEN=

# Headers obligatoires (ne pas modifier sauf si MPP change sa version client)
MPP_API_BASE_URL=https://api.mpp.football
MPP_PLATFORM=web
MPP_CLIENT_VERSION=11.12.0
MPP_CLIENT_LANGUAGE=fr-FR
MPP_APPLICATION=mppLfp
MPP_APP_CONTEXT=internationalEvent

# ============================================================
# Ligue cible
# ============================================================

# ID du défi (challenge) à afficher.
# Source : GET /user-contests → contestsCards[].contestId
# Format : mpp_challenge_XXXXXXXX
# Si absent, le service prend automatiquement le premier contest personnel.
MPP_CHALLENGE_ID=mpp_challenge_UBXC3UXL

# Filtrer par titre de ligue (alternative à MPP_CHALLENGE_ID, insensible à la casse)
# Exemple : MPP_LEAGUE_TITLE=MyTower
MPP_LEAGUE_TITLE=

# Nombre max de joueurs récupérés dans le classement (défaut : 200)
MPP_STANDINGS_LIMIT=200

# ============================================================
# Comportement
# ============================================================

# true  = données de démo (pas besoin de token)
# false = données réelles MPP (MPP_ACCESS_TOKEN requis)
MPP_USE_MOCK=false

# Durée du cache serveur en secondes (défaut : 300 = 5 min)
MPP_CACHE_TTL=300

# ============================================================
# Serveur
# ============================================================
PORT=3000
NODE_ENV=development

# Historique Turso + cron Vercel
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=
CRON_SECRET=
ALLOW_MOCK_SNAPSHOTS=false

# Fréquence effective des captures, en minutes (1 à 10080).
# Le cron Vercel appelle la route chaque minute; les appels d'un même créneau
# mettent à jour le même instantané au lieu d'en créer plusieurs.
STANDINGS_SNAPSHOT_INTERVAL_MINUTES=60

# En local, npm run dev lance son propre ordonnanceur.
LOCAL_SNAPSHOT_SCHEDULER_ENABLED=true
