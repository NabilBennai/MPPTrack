# ============================================================
# API Mon Petit Prono
# ============================================================

# Base URL de l'API MPP (ne pas modifier)
MPP_API_BASE_URL=https://api.mpp.football

# Token Bearer — récupérer depuis les DevTools (onglet Network → Authorization header)
# Ne jamais committer la valeur réelle
MPP_ACCESS_TOKEN=

# Headers client observés dans l'application MPP
MPP_PLATFORM=web
MPP_CLIENT_VERSION=11.12.0
MPP_CLIENT_LANGUAGE=fr-FR
MPP_APPLICATION=mppLfp
MPP_APP_CONTEXT=internationalEvent

# ============================================================
# Configuration classement
# ============================================================

# Laisser vide = découverte automatique depuis /user
# Remplir après avoir visité /mpp/debug/user
MPP_LEAGUE_ID=

# Laisser vide = découverte automatique
# Remplir après avoir visité /mpp/debug/probe?leagueId=VOTRE_ID
MPP_RANKING_PATH=

# ============================================================
# Comportement
# ============================================================

# true  = données de démo (ne nécessite pas MPP_ACCESS_TOKEN)
# false = données réelles (nécessite MPP_ACCESS_TOKEN)
MPP_USE_MOCK=true

# Durée du cache serveur en secondes (défaut : 300 = 5 min)
MPP_CACHE_TTL=300

# ============================================================
# Serveur
# ============================================================
PORT=3000
NODE_ENV=development
