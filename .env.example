# ============================================================
# API Mon Petit Prono — https://api.mpp.football
# ============================================================

# Token Bearer — copier depuis DevTools (onglet Network, header "Authorization")
# Le token JWT dure ~30 jours. Ne jamais committer la valeur réelle.
MPP_ACCESS_TOKEN=

# Headers obligatoires (ne pas modifier sauf si MPP change sa version client)
MPP_API_BASE_URL=https://api.mpp.football
MPP_PLATFORM=web
MPP_CLIENT_VERSION=11.12.0
MPP_CLIENT_LANGUAGE=fr-FR
MPP_APPLICATION=mppLfp
MPP_APP_CONTEXT=internationalEvent

# ============================================================
# Ligue cible
# ============================================================

# ID du défi (challenge) à afficher.
# Source : GET /user-contests → contestsCards[].contestId
# Format : mpp_challenge_XXXXXXXX
# Si absent, le service prend automatiquement le premier contest personnel.
MPP_CHALLENGE_ID=mpp_challenge_UBXC3UXL

# Filtrer par titre de ligue (alternative à MPP_CHALLENGE_ID, insensible à la casse)
# Exemple : MPP_LEAGUE_TITLE=MyTower
MPP_LEAGUE_TITLE=

# Nombre max de joueurs récupérés dans le classement (défaut : 200)
MPP_STANDINGS_LIMIT=200

# ============================================================
# Comportement
# ============================================================

# true  = données de démo (pas besoin de token)
# false = données réelles MPP (MPP_ACCESS_TOKEN requis)
MPP_USE_MOCK=false

# Durée du cache serveur en secondes (défaut : 300 = 5 min)
MPP_CACHE_TTL=300

# ============================================================
# Serveur
# ============================================================
PORT=3000
NODE_ENV=development
